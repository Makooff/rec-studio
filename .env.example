# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commiter .env.local

# Obsidian Local REST API
OBSIDIAN_API_KEY=your_obsidian_local_rest_api_key_here
OBSIDIAN_API_HOST=127.0.0.1
OBSIDIAN_API_PORT=27124

# Nom du vault Obsidian pour ce projet (sous-dossier dans le vault)
# Ex: "Qwillio", "MonApp", "Startup"
OBSIDIAN_VAULT=NomDuProjet

# 21st.dev Magic MCP
MAGIC_API_KEY=your_21st_dev_magic_key_here

# Pika — génération vidéo / ads IA (pika.art/api)
PIKA_API_KEY=your_pika_api_key_here
