{
  "env": {
    "OBSIDIAN_API_HOST": "127.0.0.1",
    "OBSIDIAN_API_PORT": "27124"
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"$CLAUDE_PROJECT_DIR/.claude/scripts/obsidian.js\" inject-context"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"$CLAUDE_PROJECT_DIR/.claude/scripts/skill-router.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"$CLAUDE_PROJECT_DIR/.claude/scripts/obsidian.js\" session-log"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "caveman@caveman": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "comprehensive-review@agents": true,
    "debugging-toolkit@agents": true,
    "unit-testing@agents": true,
    "security-scanning@agents": true,
    "full-stack-orchestration@agents": true,
    "frontend-mobile-development@agents": true,
    "ui-design@agents": true,
    "cicd-automation@agents": true,
    "agent-orchestration@agents": true,
    "application-performance@agents": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "agents": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark"
}
